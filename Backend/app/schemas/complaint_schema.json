{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GeminiComplaintResponse",
  "description": "JSON schema for Gemini AI response when processing complaint calls",
  "type": "object",
  "properties": {
    "intent": {
      "type": "string",
      "description": "Classified intent of the caller",
      "enum": ["complaint", "status_check", "general_inquiry", "emergency", "unknown"]
    },
    "complaint_type": {
      "type": "string",
      "description": "Type of complaint being reported",
      "enum": [
        "garbage_collection",
        "missed_collection",
        "streetlight",
        "water_supply",
        "drainage",
        "road_repair",
        "stray_animal",
        "encroachment",
        "other"
      ]
    },
    "fields": {
      "type": "object",
      "description": "Extracted structured data from the conversation",
      "properties": {
        "address": {
          "type": "string",
          "description": "Full address of the complaint location"
        },
        "contact_number": {
          "type": "string",
          "description": "Contact phone number of the caller"
        },
        "pincode": {
          "type": "string",
          "description": "Postal code of the location"
        },
        "landmark": {
          "type": "string",
          "description": "Nearby landmark for easier identification"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the issue"
        },
        "ticket_number": {
          "type": "string",
          "description": "Existing ticket number for status checks"
        }
      }
    },
    "missing_fields": {
      "type": "array",
      "description": "List of required fields that are still missing",
      "items": {
        "type": "string",
        "enum": ["address", "contact_number", "pincode", "description"]
      }
    },
    "confidence": {
      "type": "object",
      "description": "Confidence scores (0-1) for each extracted field",
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    },
    "next_action": {
      "type": "string",
      "description": "What the system should do next",
      "enum": ["ask", "confirm", "file", "escalate", "end"]
    },
    "speak": {
      "type": "string",
      "description": "Text to speak to the caller (in their language)"
    },
    "language_detected": {
      "type": "string",
      "description": "Detected language of the caller",
      "enum": ["hi", "gu", "en"]
    },
    "sentiment": {
      "type": "string",
      "description": "Detected emotional state of the caller",
      "enum": ["positive", "neutral", "negative", "frustrated"]
    },
    "urgency_suggested": {
      "type": "string",
      "description": "AI-suggested urgency level based on content",
      "enum": ["low", "medium", "high", "critical"]
    }
  },
  "required": ["intent", "fields", "next_action", "speak"],
  "examples": [
    {
      "intent": "complaint",
      "complaint_type": "missed_collection",
      "fields": {
        "address": "12 MG Road, Sayajiganj, Vadodara",
        "contact_number": "+9198210XXXXX"
      },
      "missing_fields": ["pincode"],
      "confidence": {
        "address": 0.92,
        "contact_number": 0.85
      },
      "next_action": "ask",
      "speak": "Can you tell me the pincode for your address?",
      "language_detected": "hi",
      "sentiment": "neutral",
      "urgency_suggested": "medium"
    }
  ]
}
